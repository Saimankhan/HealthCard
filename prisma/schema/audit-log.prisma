model AuditLog {
  id         String      @id @default(uuid())
  actorId    String?
  actor      User?       @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String
  entityId   String?
  metadata   Json?
  ipAddress  String?
  createdAt  DateTime    @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_log")
}
