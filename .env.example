# =========================================================================
# HealthCard — environment variable reference
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =========================================================================

NODE_ENV=development

# ---------------------------------------------------------------------
# App
# ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------------
# Database (Neon Postgres via Prisma)
# DATABASE_URL = pooled connection (runtime queries, via PgBouncer -pooler host)
# DIRECT_URL   = direct connection (migrations / introspection, no pooler)
# ---------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require"

# ---------------------------------------------------------------------
# Better Auth
# Generate a secret with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ---------------------------------------------------------------------
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ---------------------------------------------------------------------
# Upstash Redis
# ---------------------------------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------------------------------------------------------------------
# Cloudflare R2 (S3-compatible storage)
# ---------------------------------------------------------------------
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# ---------------------------------------------------------------------
# Gmail SMTP (Nodemailer)
# Use a Gmail App Password, not your regular account password.
# ---------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HealthCard <your-address@gmail.com>"

# ---------------------------------------------------------------------
# Stripe (TEST MODE ONLY — never use live keys)
# STRIPE_WEBHOOK_SECRET comes from `stripe listen --print-secret`
# or the Stripe Dashboard's webhook endpoint settings.
# ---------------------------------------------------------------------
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------
# Twilio (SMS) — optional. If unset, SMS sends are skipped with a warning
# instead of failing the request.
# ---------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ---------------------------------------------------------------------
# Background jobs
# Bearer token required by /api/cron/* endpoints (Vercel Cron, QStash,
# or any external scheduler). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ---------------------------------------------------------------------
CRON_SECRET=
